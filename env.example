# ============================================================
# Options Trading Bot — Environment Variables
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to GitHub (it's in .gitignore)
# ============================================================

# --- Telegram ---
# Get bot token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=yout_bot_token
# Get chat ID from @userinfobot in Telegram
TELEGRAM_CHAT_ID=your_chat_id

# --- Schwab API ---
SCHWAB_API_KEY=your_schwab_app_key_here
SCHWAB_APP_SECRET=your_schwab_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=schwab_token.json
